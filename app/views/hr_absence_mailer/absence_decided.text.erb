<%= l(:mail_body_hr_absence_decided_intro,
       user: @user.name,
       kind: HrAbsence.kind_label(@absence.kind),
       status: HrAbsence.status_label(@absence.status)) %>

<%= l(:label_hr_absence_period) %>: <%= I18n.l(@absence.starts_on) %> – <%= I18n.l(@absence.ends_on) %>
<%= l(:mail_label_working_days, count: @breakdown[:working]) %>

<% if @absence.approver %>
<%= l(:label_hr_absence_approved_by) %>: <%= @absence.approver.name %>
<% if @absence.approved_at %>
<%= l(:field_updated_on) %>: <%= I18n.l(@absence.approved_at, format: :default) rescue @absence.approved_at %>
<% end %>
<% end %>

