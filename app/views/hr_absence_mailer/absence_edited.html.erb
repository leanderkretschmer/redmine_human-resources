<p><%= l(:mail_body_hr_absence_edited_intro,
        user: h(@user.name),
        editor: h(@editor.name),
        kind: h(HrAbsence.kind_label(@absence.kind))).html_safe %></p>

<p>
  <strong><%= l(:label_hr_absence_period) %>:</strong>
  <%= I18n.l(@absence.starts_on) %> – <%= I18n.l(@absence.ends_on) %>
</p>
<p>
  <strong><%= l(:label_hr_absence_status) %>:</strong>
  <%= h HrAbsence.status_label(@absence.status) %>
</p>
<p>
  <strong><%= l(:mail_label_working_days, count: @breakdown[:working]) %></strong>
</p>

<% if @absence.reason.present? %>
  <h3><%= l(:label_hr_absence_reason) %></h3>
  <p style="white-space: pre-wrap;"><%= h @absence.reason %></p>
<% end %>

<hr>
<p>
  <%= link_to l(:mail_link_view_in_redmine),
              url_for(controller: 'hr_vacation', action: 'show', only_path: false) %>
</p>
