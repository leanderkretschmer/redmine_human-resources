<%= I18n.t(:mail_body_hr_absence_requested_intro,
           user: @user.name,
           kind: HrAbsence.kind_label(@absence.kind)) %>

<%= l(:label_hr_absence_period) %>: <%= I18n.l(@absence.starts_on) %> – <%= I18n.l(@absence.ends_on) %>

<%= l(:mail_label_breakdown) %>:
- <%= l(:mail_label_working_days, count: @breakdown[:working]) %>
- <%= l(:mail_label_weekend_days, count: @breakdown[:weekend]) %>
- <%= l(:mail_label_holiday_days, count: @breakdown[:holidays].size) %>
<% @breakdown[:holidays].each do |h| %>
  · <%= I18n.l(h[:date]) %>: <%= h[:name] %>
<% end %>
<%= l(:mail_label_total_days, count: @breakdown[:total]) %>

<% if @absence.reason.present? %>

<%= l(:label_hr_absence_reason) %>:
<%= @absence.reason %>
<% end %>

<% if @conflicts.any? %>

<%= l(:mail_label_conflicts, padding: ::RedmineHumanResources::Notifications.conflict_padding_days) %>:
<% @conflicts.each do |c| %>
- <%= c.user.name %>: <%= I18n.l(c.starts_on) %> – <%= I18n.l(c.ends_on) %> (<%= c.days %> <%= l(:label_hr_absence_days) %>)
<% end %>
<% else %>

<%= l(:mail_label_no_conflicts, padding: ::RedmineHumanResources::Notifications.conflict_padding_days) %>
<% end %>

---
<%= l(:mail_link_view_in_redmine) %>: <%= url_for(controller: 'hr_admin', action: 'index', only_path: false) %>
