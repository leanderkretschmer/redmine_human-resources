<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'hr_timeclock', plugin: 'redmine_human_resources' %>
<% end %>

<div class="contextual">
  <%= link_to l(:button_hr_employment_type_new), new_hr_admin_employment_type_path, class: 'icon icon-add' %>
  <%= link_to l(:label_hr_admin_back), hr_admin_path, class: 'icon icon-back' %>
</div>

<h2><%= l(:label_hr_admin_employment_types) %></h2>

<% if @types.empty? %>
  <p class="nodata"><%= l(:label_hr_admin_employment_types_none) %></p>
<% else %>
  <table class="list">
    <thead>
      <tr>
        <th><%= l(:label_hr_employment_type) %></th>
        <th><%= l(:label_hr_employment_type_slug) %></th>
        <th><%= l(:label_hr_employment_type_daily) %></th>
        <th><%= l(:label_hr_employment_type_weekly) %></th>
        <th><%= l(:label_hr_employment_type_break) %></th>
        <th><%= l(:label_hr_employment_type_vacation) %></th>
        <th><%= l(:label_hr_employment_type_school_days) %></th>
        <th><%= l(:label_hr_employment_type_monthly_plan) %></th>
        <th><%= l(:label_hr_employment_type_archived) %></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @types.each do |t| %>
        <tr class="<%= cycle('odd', 'even') %><%= ' hr-tc-archived' if t.archived? %>">
          <td><%= h t.name %></td>
          <td><code><%= h t.slug %></code></td>
          <td><%= t.daily_target_minutes ? (t.daily_target_minutes / 60.0).round(2) : '—' %> h</td>
          <td><%= t.weekly_target_minutes ? (t.weekly_target_minutes / 60.0).round(2) : '—' %> h</td>
          <td><%= (t.max_break_minutes / 60.0).round(2) %> h</td>
          <td><%= t.yearly_vacation_days %></td>
          <td><%= t.weekly_school_days %></td>
          <td><%= t.allows_monthly_plan? ? '✓' : '—' %></td>
          <td><%= t.archived? ? '✓' : '' %></td>
          <td>
            <%= link_to l(:button_hr_absence_edit), edit_hr_admin_employment_type_path(t), class: 'icon icon-edit' %>
            <% unless t.archived? %>
              <%= link_to l(:button_hr_absence_delete), hr_admin_employment_type_path(t), method: :delete,
                          data: { confirm: l(:text_are_you_sure) }, class: 'icon icon-del' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
