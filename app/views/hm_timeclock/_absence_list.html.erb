<% if absences.empty? %>
  <p class="nodata"><%= l(:label_hm_absence_none) %></p>
<% else %>
  <table class="list">
    <thead>
      <tr>
        <th><%= l(:label_hm_absence_period) %></th>
        <th><%= l(:label_hm_absence_days) %></th>
        <th><%= l(:label_hm_absence_status) %></th>
        <th><%= l(:label_hm_absence_reason) %></th>
        <th><%= l(:label_hm_absence_history) %></th>
        <% if local_assigns[:show_user] %>
          <th><%= l(:label_hm_admin_user) %></th>
        <% end %>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% absences.each do |a| %>
        <tr class="hm-tc-abs-row hm-tc-abs-<%= a.status %>">
          <td><%= I18n.l(a.starts_on) %> — <%= I18n.l(a.ends_on) %></td>
          <td>
            <%= a.days %>
            <% if a.vacation? %>
              <% rem = HmAbsence.vacation_remaining(a.user, a.starts_on.year) %>
              <span class="hm-tc-vacation-remaining" title="<%= l(:label_hm_vacation_remaining_full, used: rem[:used], allowed: rem[:allowed], year: a.starts_on.year) %>">
                · <%= l(:label_hm_vacation_remaining_short, remaining: rem[:remaining], allowed: rem[:allowed]) %>
              </span>
            <% end %>
          </td>
          <td>
            <span class="hm-tc-abs-pill hm-tc-abs-pill-<%= a.kind %><%= ' hm-tc-abs-pill-pending' if a.requested? %>">
              <%= HmAbsence.kind_label(a.kind) %><% unless a.approved? %> · <%= HmAbsence.status_label(a.status) %><% end %>
            </span>
          </td>
          <td><%= h a.reason %></td>
          <td class="hm-tc-abs-audit-cell">
            <% audits = a.audits.includes(:actor).to_a %>
            <% if audits.empty? && a.approver %>
              <div class="hm-tc-abs-audit-entry">
                <strong><%= HmAbsenceAudit.action_label(a.approved? ? 'approved' : 'rejected') %>:</strong>
                <%= h(a.approver.name) %>
                <small>(<%= format_time(a.approved_at) if a.approved_at %>)</small>
              </div>
            <% end %>
            <% audits.each do |audit| %>
              <div class="hm-tc-abs-audit-entry hm-tc-abs-audit-<%= audit.action %>">
                <strong><%= HmAbsenceAudit.action_label(audit.action) %>:</strong>
                <%= h(audit.actor&.name || '?') %>
                <small>(<%= format_time(audit.created_at) %>)</small>
              </div>
            <% end %>
          </td>
          <% if local_assigns[:show_user] %>
            <td><%= link_to h(a.user.name), hm_admin_user_path(user_id: a.user.id) %></td>
          <% end %>
          <td class="hm-tc-abs-actions">
            <% if User.current.admin? && a.requested? %>
              <%= button_to l(:button_hm_absence_approve), approve_hm_absence_path(id: a.id), method: :post, class: 'button-positive' %>
              <%= button_to l(:button_hm_absence_reject),  reject_hm_absence_path(id: a.id),  method: :post, class: 'button-negative' %>
            <% end %>
            <% if (a.user_id == User.current.id && (a.requested? || a.sickness? || a.offsite?)) || User.current.admin? %>
              <a href="#" class="icon icon-edit hm-tc-edit-absence-btn"
                 data-absence-id="<%= a.id %>"
                 data-update-url="<%= hm_absence_path(id: a.id) %>"
                 data-starts-on="<%= a.starts_on.iso8601 %>"
                 data-ends-on="<%= a.ends_on.iso8601 %>"
                 data-reason="<%= h a.reason %>"
                 data-status="<%= a.status %>"
                 data-kind="<%= a.kind %>"
                 data-kind-label="<%= h HmAbsence.kind_label(a.kind) %>"><%= l(:button_hm_absence_edit) %></a>
              <%= button_to l(:button_hm_absence_delete), hm_absence_path(id: a.id), method: :delete, class: 'icon icon-del',
                            data: { confirm: l(:text_are_you_sure) } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
