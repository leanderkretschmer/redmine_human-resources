<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'hm_timeclock', plugin: 'redmine_human_resources' %>
<% end %>

<div class="contextual">
  <%= link_to l(:label_hm_admin_export_csv),
              export_hr_timeclock_path(month: @month.strftime('%Y-%m')),
              class: 'icon icon-download' %>
  <%= link_to l(:label_hm_timeclock_settings),
              edit_hr_timeclock_settings_path,
              class: 'icon icon-settings' %>
</div>

<h2><%= l(:label_hm_timeclock_title) %></h2>

<% if @snapshot[:pending_correction] %>
  <%= render partial: 'correction_banner', locals: { pc: @snapshot[:pending_correction] } %>
<% end %>

<div id="hm-timeclock-card"
     data-status-url="<%= hr_timeclock_status_path(format: :json) %>"
     data-snapshot="<%= h @snapshot.to_json %>">
  <div class="hm-tc-state-row">
    <span class="hm-tc-status hm-tc-status-<%= @snapshot[:state] %>" data-bind="state-label">
      <%= hm_state_label(@snapshot[:state]) %>
    </span>
    <span class="hm-tc-clock-started" data-show-when="working,on_break">
      <%= l(:label_hm_timeclock_session_started_at) %>:
      <span data-bind="started-at"><%= @snapshot[:work_started_at_unix] ? format_time(Time.at(@snapshot[:work_started_at_unix])) : '—' %></span>
    </span>
  </div>

  <div class="hm-tc-clock">
    <span class="hm-tc-clock-worked" data-bind="worked">
      <%= hm_format_seconds_with_seconds(@snapshot[:worked_seconds_today]) %>
    </span>
    <span class="hm-tc-clock-label"><%= l(:label_hm_timeclock_worked_today) %></span>
  </div>

  <div class="hm-tc-meta">
    <div>
      <strong><%= l(:label_hm_timeclock_target_today) %>:</strong>
      <%= hm_format_seconds(@snapshot[:daily_target_seconds]) %>
    </div>
    <div>
      <strong><%= l(:label_hm_timeclock_break_today) %>:</strong>
      <span data-bind="break_total"><%= hm_format_seconds(@snapshot[:total_break_seconds_today]) %></span>
      / <%= hm_format_seconds(@snapshot[:max_break_seconds]) %>
    </div>
    <div data-show-when="on_break">
      <strong><%= l(:label_hm_timeclock_break_started_at) %>:</strong>
      <span data-bind="current_break"><%= hm_format_seconds_with_seconds(@snapshot[:current_break_seconds]) %></span>
    </div>
    <div class="hm-tc-expected-end" data-show-when="working,on_break" data-hide-when-overtime="1">
      <strong><%= l(:label_hm_timeclock_expected_end) %>:</strong>
      <span data-bind="expected_end">
        <%= @snapshot[:expected_end_unix] ? Time.at(@snapshot[:expected_end_unix]).in_time_zone(User.current.time_zone || Time.zone).strftime('%H:%M') : '--:--' %>
      </span>
    </div>
    <div class="hm-tc-overtime" data-show-when="working,on_break" data-show-when-overtime="1">
      <strong><%= l(:label_hm_timeclock_overtime) %>:</strong>
      <span data-bind="overtime">
        <%= l(:label_hm_timeclock_overtime_prefix) %><%= hm_format_seconds(@snapshot[:overtime_seconds]) %>
      </span>
    </div>
  </div>

  <div class="hm-tc-prefs">
    <label class="hm-tc-toggle">
      <input type="checkbox" id="hm-tc-toggle-nav-end" checked>
      <span><%= l(:label_hm_toggle_nav_end) %></span>
    </label>
  </div>

  <div class="hm-tc-actions">
    <%= button_to l(:button_hm_timeclock_start),  start_hr_timeclock_path,
                  data: { state_visible: 'idle' },
                  class: 'hm-tc-btn hm-tc-btn-start' %>
    <%= button_to l(:button_hm_timeclock_pause),  pause_hr_timeclock_path,
                  data: { state_visible: 'working' },
                  class: 'hm-tc-btn hm-tc-btn-pause' %>
    <%= button_to l(:button_hm_timeclock_resume), resume_hr_timeclock_path,
                  data: { state_visible: 'on_break' },
                  class: 'hm-tc-btn hm-tc-btn-resume' %>
    <%= button_to l(:button_hm_timeclock_stop),   stop_hr_timeclock_path,
                  data: { state_visible: 'working,on_break' },
                  class: 'hm-tc-btn hm-tc-btn-stop' %>
  </div>
</div>

<% if @chart_metrics %>
  <h3><%= l(:label_hm_personal_chart_title) %></h3>
  <%= form_with url: hr_timeclock_path, method: :get, local: true, html: { class: 'hm-tc-barchart-toggle' } do %>
    <%= hidden_field_tag :month, @month.strftime('%Y-%m') %>
    <strong><%= l(:label_hm_admin_chart_view) %>:</strong>
    <% %w[today week month].each do |mode| %>
      <label class="hm-tc-chart-view-option">
        <%= radio_button_tag :chart_view, mode, @chart_view == mode, onchange: 'this.form.submit()' %>
        <%= l("label_hm_admin_chart_view_#{mode}") %>
      </label>
    <% end %>
  <% end %>
  <%
    work_s   = @chart_metrics[:work].to_i
    break_s  = @chart_metrics[:break_secs].to_i
    cover_s  = @chart_metrics[:coverage].to_i
    total    = work_s + break_s
    scale    = total.positive? ? total : 1
    work_pct = (work_s.to_f / scale * 100).round(2)
    brk_pct  = (break_s.to_f / scale * 100).round(2)
    cov_pct  = ([cover_s, work_s].min.to_f / scale * 100).round(2)
    work_title    = "#{l(:label_hm_admin_bar_work)}: #{hm_format_seconds(work_s)}"
    break_title   = "#{l(:label_hm_admin_bar_break)}: #{hm_format_seconds(break_s)}"
    coverage_title = "#{l(:label_hm_admin_bar_coverage)}: #{hm_format_seconds(cover_s)}"
  %>
  <div class="hm-tc-barchart">
    <div class="hm-tc-bar-row">
      <span class="hm-tc-bar-name"><%= h User.current.name %></span>
      <span class="hm-tc-bar-track hm-tc-bar-track-stacked">
        <span class="hm-tc-bar-seg hm-tc-bar-seg-work"
              style="width: <%= [work_pct, 0.5].max %>%"
              title="<%= h work_title %>"></span>
        <% if break_s.positive? %>
          <span class="hm-tc-bar-seg hm-tc-bar-seg-break"
                style="width: <%= [brk_pct, 0.5].max %>%"
                title="<%= h break_title %>"></span>
        <% end %>
        <% if cover_s.positive? && work_s.positive? %>
          <span class="hm-tc-bar-seg hm-tc-bar-seg-coverage"
                style="left: 0; width: <%= [cov_pct, 0.5].max %>%"
                title="<%= h coverage_title %>"></span>
        <% end %>
      </span>
      <span class="hm-tc-bar-value" title="<%= h work_title %>"><%= hm_format_seconds(work_s) %></span>
    </div>
  </div>
<% end %>

<h3><%= l(:label_hm_timeclock_today) %></h3>
<%= render partial: 'entries_table', locals: { entries: @entries_today } %>

<h3><%= l(:label_hm_timeclock_calendar) %></h3>
<%= render partial: 'calendar', locals: {
      month: @month, entries: @entries_month, user: User.current,
      base_path: ->(m) { hr_timeclock_path(month: m.strftime('%Y-%m')) },
      absences_by_day: @absences_by_day,
      lecture_periods: @lecture_periods,
      monthly_plan: @monthly_plan,
      holidays_by_day: @holidays_by_day,
      clickable_for_absence: true
    } %>

<%= render partial: 'absence_modal' %>
<%= render partial: 'day_detail_modal' %>
