<div id="hm-absence-edit-modal" class="hm-tc-popup" role="dialog" aria-modal="true" aria-hidden="true"
     data-csrf="<%= form_authenticity_token %>">
  <div class="hm-tc-popup-inner hm-tc-absence-modal-inner">
    <h3 class="hm-tc-absence-modal-title"><%= l(:label_hm_absence_edit_title, kind: '') %></h3>
    <form id="hm-absence-edit-form" autocomplete="off">
      <div class="hm-tc-absence-modal-row">
        <label><%= l(:label_hm_absence_starts_on) %></label>
        <input type="date" name="starts_on" id="hm_absence_edit_starts_on" required>
      </div>
      <div class="hm-tc-absence-modal-row">
        <label><%= l(:label_hm_absence_ends_on) %></label>
        <input type="date" name="ends_on" id="hm_absence_edit_ends_on" required>
      </div>
      <div class="hm-tc-absence-modal-row">
        <label><%= l(:label_hm_absence_reason) %></label>
        <textarea name="reason" id="hm_absence_edit_reason" rows="3"></textarea>
      </div>
      <% if User.current.admin? %>
        <div class="hm-tc-absence-modal-row hm-tc-edit-status-row">
          <label><%= l(:label_hm_absence_status) %></label>
          <select name="status" id="hm_absence_edit_status">
            <option value="requested"><%= l(:label_hm_absence_status_requested) %></option>
            <option value="approved"><%= l(:label_hm_absence_status_approved) %></option>
            <option value="rejected"><%= l(:label_hm_absence_status_rejected) %></option>
          </select>
        </div>
      <% end %>
      <div class="hm-tc-absence-modal-actions">
        <button type="submit" class="button-positive"><%= l(:button_hm_absence_save) %></button>
        <button type="button" class="hm-tc-absence-modal-cancel"><%= l(:button_cancel) %></button>
      </div>
    </form>
  </div>
</div>
