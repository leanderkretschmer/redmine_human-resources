<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'hm_timeclock', plugin: 'redmine_human_resources' %>
<% end %>

<div class="contextual">
  <%= link_to l(:label_hm_admin_import_back), hm_admin_import_path, class: 'icon icon-back' %>
</div>

<h2><%= l(:label_hm_admin_import) %> — <%= l(:label_hm_import_preview_title) %></h2>

<p class="hm-tc-section-hint"><%= l(:label_hm_import_preview_intro, count: @rows.size) %></p>

<%= form_with url: hm_admin_import_commit_path, method: :post, local: true do %>
  <p class="hm-tc-import-bulk">
    <label for="hm-import-bulk-user"><%= l(:label_hm_import_assign_all) %></label>
    <select id="hm-import-bulk-user">
      <option value=""><%= l(:label_hm_import_assign_all_blank) %></option>
      <% @users.each do |u| %>
        <option value="<%= u.id %>"><%= h u.name %> (<%= h u.login %>)</option>
      <% end %>
    </select>
  </p>

  <table class="list hm-tc-import-table">
    <thead>
      <tr>
        <th><input type="checkbox" id="hm-import-toggle-all" checked></th>
        <th>#</th>
        <th><%= l(:label_hm_import_col_date) %></th>
        <th><%= l(:label_hm_import_col_start) %></th>
        <th><%= l(:label_hm_import_col_end) %></th>
        <th><%= l(:label_hm_import_col_gross) %></th>
        <th><%= l(:label_hm_import_col_break) %></th>
        <th><%= l(:label_hm_import_col_login) %></th>
        <th><%= l(:label_hm_import_col_assign) %></th>
        <th><%= l(:label_hm_import_col_notes) %></th>
      </tr>
    </thead>
    <tbody>
      <% @rows.each_with_index do |row, i| %>
        <tr class="<%= cycle('odd','even') %><%= ' hm-tc-import-invalid' unless row[:valid] %>">
          <td>
            <%= check_box_tag "rows[#{i}][include]", '1', row[:valid] && row[:user_id].present?,
                              class: 'hm-import-include' %>
          </td>
          <td><%= i + 1 %></td>
          <td>
            <%= row[:date] %>
            <%= hidden_field_tag "rows[#{i}][date]",  row[:date] %>
          </td>
          <td>
            <%= row[:start] %>
            <%= hidden_field_tag "rows[#{i}][start]", row[:start] %>
          </td>
          <td>
            <%= row[:end] %>
            <%= hidden_field_tag "rows[#{i}][end]",   row[:end] %>
          </td>
          <td>
            <% if row[:valid] %><%= row[:gross_label] %><% else %><span class="hm-tc-import-err">⚠</span><% end %>
          </td>
          <td>
            <%= row[:break_minutes] %>
            <%= hidden_field_tag "rows[#{i}][break_minutes]", row[:break_minutes] %>
          </td>
          <td><%= h row[:login] %></td>
          <td>
            <%= select_tag "rows[#{i}][user_id]",
                  options_for_select([[l(:label_hm_import_assign_none), '']] +
                    @users.map { |u| ["#{u.name} (#{u.login})", u.id] }, row[:user_id]),
                  class: 'hm-import-user' %>
          </td>
          <td>
            <%= h row[:notes] %>
            <%= hidden_field_tag "rows[#{i}][notes]", row[:notes] %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <p><%= submit_tag l(:button_hm_import_commit), class: 'button-positive' %></p>
<% end %>

<script>
  (function () {
    var bulk = document.getElementById('hm-import-bulk-user');
    if (bulk) {
      bulk.addEventListener('change', function () {
        if (!bulk.value) return;
        document.querySelectorAll('select.hm-import-user').forEach(function (sel) {
          sel.value = bulk.value;
          var row = sel.closest('tr');
          var inc = row && row.querySelector('input.hm-import-include');
          if (inc && !row.classList.contains('hm-tc-import-invalid')) inc.checked = true;
        });
      });
    }
    var toggle = document.getElementById('hm-import-toggle-all');
    if (toggle) {
      toggle.addEventListener('change', function () {
        document.querySelectorAll('input.hm-import-include').forEach(function (cb) {
          if (!cb.closest('tr').classList.contains('hm-tc-import-invalid')) cb.checked = toggle.checked;
        });
      });
    }
  })();
</script>
