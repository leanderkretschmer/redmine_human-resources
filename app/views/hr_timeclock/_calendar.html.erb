<%
  totals          = hr_totals_by_day(entries, user&.time_zone)
  absences_by_day = local_assigns[:absences_by_day]
  day_link        = local_assigns[:day_link]
  show_users      = local_assigns[:show_users_in_absence]
  clickable       = local_assigns[:clickable_for_absence]
  default_kind    = local_assigns[:default_absence_kind]
  lecture_periods = local_assigns[:lecture_periods]
  monthly_plan    = local_assigns[:monthly_plan]
  holidays_by_day = local_assigns[:holidays_by_day]
  view_mode       = (local_assigns[:view_mode] || 'month').to_s
  view_mode       = 'month' unless %w[month week].include?(view_mode)
  week_path       = local_assigns[:week_path]   # ->(Date) { url } — required for week toggle/nav
  focus_date      = local_assigns[:focus_date]  # used for week nav targets and for the toggle's anchor day
  focus_date    ||= (view_mode == 'week' ? Date.current : month.to_date)
  week_start      = view_mode == 'week' ? focus_date.beginning_of_week : nil
  week_end        = week_start ? week_start + 6 : nil
  day_names       = (I18n.t('date.abbr_day_names') || %w[Sun Mon Tue Wed Thu Fri Sat]).rotate(1)
  lecture_range_from = view_mode == 'week' ? week_start : month
  lecture_range_to   = view_mode == 'week' ? week_end   : month.end_of_month
  lecture_by_day  = {}
  (lecture_periods || []).each do |lp|
    from = [lp.starts_on, lecture_range_from].max
    to   = [lp.ends_on,   lecture_range_to].min
    next if from > to
    (from..to).each { |d| (lecture_by_day[d] ||= []) << lp }
  end

  # Per-day work-entry buckets (only needed for week view's hour grid).
  tz_for_entries = user&.time_zone || Time.zone
  entries_by_day = Hash.new { |h, k| h[k] = [] }
  if view_mode == 'week'
    entries.each do |e|
      d = e.started_at.in_time_zone(tz_for_entries).to_date
      entries_by_day[d] << e if d >= week_start && d <= week_end
    end
  end

  # Hour window for week view's timeline (default 06:00–22:00, configurable
  # via locals if a calendar caller cares).
  week_start_hour = (local_assigns[:week_start_hour] || 6).to_i
  week_end_hour   = (local_assigns[:week_end_hour]   || 22).to_i
  week_hours      = week_end_hour - week_start_hour
%>
<div class="hr-tc-calendar"
     <%= "data-default-absence-kind=\"#{h default_kind}\"".html_safe if default_kind %>
     <%= 'data-admin-create="1"'.html_safe if show_users %>>
  <% if week_path %>
    <div class="hr-tc-cal-view-toggle">
      <%= link_to l(:label_hr_admin_view_mode_month), base_path.call((focus_date || Date.current).beginning_of_month),
                  class: "hr-tc-cal-view-toggle-btn #{'active' if view_mode == 'month'}" %>
      <%= link_to l(:label_hr_admin_view_mode_week), week_path.call(focus_date || Date.current),
                  class: "hr-tc-cal-view-toggle-btn #{'active' if view_mode == 'week'}" %>
    </div>
  <% end %>
  <div class="hr-tc-calendar-nav">
    <% if view_mode == 'week' %>
      <%= link_to '«', week_path.call(week_start - 7), class: 'hr-tc-cal-nav-btn' %>
      <span class="hr-tc-calendar-title">
        <%= I18n.l(week_start, format: '%d.%m.') %> – <%= I18n.l(week_end, format: '%d.%m.%Y') %>
        (KW <%= week_start.cweek %>)
      </span>
      <%= link_to '»', week_path.call(week_start + 7), class: 'hr-tc-cal-nav-btn' %>
    <% else %>
      <%= link_to '«', base_path.call(month.prev_month), class: 'hr-tc-cal-nav-btn' %>
      <span class="hr-tc-calendar-title"><%= I18n.l(month, format: '%B %Y') %></span>
      <%= link_to '»', base_path.call(month.next_month), class: 'hr-tc-cal-nav-btn' %>
    <% end %>
    <% if absences_by_day %>
      <span class="hr-tc-cal-legend">
        <span class="hr-tc-cal-legend-swatch hr-tc-cal-legend-vacation"></span> <%= l(:label_hr_vacation) %>
        <span class="hr-tc-cal-legend-swatch hr-tc-cal-legend-sickness"></span> <%= l(:label_hr_sickness) %>
        <span class="hr-tc-cal-legend-swatch hr-tc-cal-legend-offsite"></span> <%= l(:label_hr_offsite) %>
        <% if lecture_by_day.any? %>
          <span class="hr-tc-cal-legend-swatch hr-tc-cal-legend-lecture"></span> <%= l(:label_hr_cal_legend_lecture) %>
        <% end %>
        <% if holidays_by_day&.any? %>
          <span class="hr-tc-cal-legend-swatch hr-tc-cal-legend-holiday"></span> <%= l(:label_hr_cal_legend_holiday) %>
        <% end %>
        <span class="hr-tc-cal-legend-swatch hr-tc-cal-legend-pending"></span> <%= l(:label_hr_absence_pending_legend) %>
      </span>
    <% end %>
    <% if clickable %>
      <span class="hr-tc-cal-hint"><%= l(:label_hr_calendar_click_hint) %></span>
    <% end %>
  </div>
  <% if monthly_plan %>
    <%
      mp_target_hours = (monthly_plan.target_minutes / 60.0).round(1)
      mp_daily_h      = (monthly_plan.daily_target_minutes / 60.0).round(2)
    %>
    <p class="hr-tc-cal-plan-banner">
      <strong><%= l(:label_hr_admin_monthly_plans) %>:</strong>
      <%= l(:label_hr_cal_monthly_plan_summary, hours: mp_target_hours, daily: mp_daily_h) %>
      <% if monthly_plan.notes.present? %><span class="hr-tc-cal-plan-note">— <%= h monthly_plan.notes %></span><% end %>
    </p>
  <% end %>

  <% if view_mode == 'week' %>
    <div class="hr-tc-cal-week"
         data-week-start-hour="<%= week_start_hour %>"
         data-week-end-hour="<%= week_end_hour %>">
      <div class="hr-tc-cal-week-hours-axis">
        <% (week_start_hour..week_end_hour).each do |h| %>
          <div class="hr-tc-cal-week-hour-tick" style="top: <%= ((h - week_start_hour).to_f / week_hours * 100).round(2) %>%">
            <%= format('%02d:00', h) %>
          </div>
        <% end %>
      </div>
      <% (week_start..week_end).each do |day| %>
        <%
          day_absences = (absences_by_day && absences_by_day[day]) || []
          day_lectures = lecture_by_day[day] || []
          day_holidays = (holidays_by_day && holidays_by_day[day]) || []
          day_entries  = entries_by_day[day] || []

          col_classes = ['hr-tc-cal-week-col']
          col_classes << 'hr-tc-cal-today'   if day == Date.current
          col_classes << 'hr-tc-cal-weekend' if [6, 7].include?(day.cwday)
          col_classes << 'hr-tc-cal-clickable' if clickable
          col_classes << 'hr-tc-cal-holiday' if day_holidays.any?

          col_attrs = +%(class="#{col_classes.join(' ')}")
          if clickable
            col_attrs << %( data-date="#{day.iso8601}")
            if day_absences.any?
              ids = day_absences.map(&:id).join(',')
              kinds = day_absences.map(&:kind).uniq.join(',')
              col_attrs << %( data-absence-ids="#{ids}")
              col_attrs << %( data-absence-kinds="#{kinds}")
            end
          end

          partial_absences = day_absences.select(&:partial?)
          fullday_absences = day_absences - partial_absences
        %>
        <div <%= col_attrs.html_safe %>>
          <div class="hr-tc-cal-week-col-head">
            <span class="hr-tc-cal-week-col-day"><%= day_names[day.cwday % 7] %></span>
            <% if day_link %>
              <%= link_to day_link.call(day), class: 'hr-tc-cal-day-link hr-tc-cal-week-col-date' do %>
                <%= day.day %>.<%= day.month %>.
              <% end %>
            <% else %>
              <span class="hr-tc-cal-week-col-date"><%= day.day %>.<%= day.month %>.</span>
            <% end %>
          </div>
          <% if day_holidays.any? || day_lectures.any? || fullday_absences.any? %>
            <div class="hr-tc-cal-week-fullday">
              <% day_holidays.each do |hd| %>
                <span class="hr-tc-abs-pill hr-tc-abs-pill-holiday" title="<%= h hd[:name] %>"><%= h hd[:name] %></span>
              <% end %>
              <% day_lectures.each do |lp| %>
                <span class="hr-tc-abs-pill hr-tc-abs-pill-lecture<%= '-break' if lp.break? %>"
                      title="<%= h lp.effective_label %>"><%= h lp.effective_label %></span>
              <% end %>
              <% fullday_absences.each do |a| %>
                <%
                  parts = [a.user.name, HrAbsence.kind_label(a.kind)] if show_users
                  parts ||= [HrAbsence.kind_label(a.kind)]
                  parts << HrAbsence.status_label(a.status) unless a.approved?
                %>
                <span class="hr-tc-abs-pill hr-tc-abs-pill-<%= a.kind %><%= ' hr-tc-cal-user-pill-pending' if a.requested? %>"
                      title="<%= h(parts.join(' — ')) %>">
                  <%= h(show_users ? a.user.login : HrAbsence.kind_label(a.kind)) %>
                </span>
              <% end %>
            </div>
          <% end %>
          <div class="hr-tc-cal-week-hours">
            <% (week_start_hour..week_end_hour).each do |h| %>
              <div class="hr-tc-cal-week-hour-rule" style="top: <%= ((h - week_start_hour).to_f / week_hours * 100).round(2) %>%"></div>
            <% end %>
            <%
              # Helper: convert "HH:MM" → minutes offset from week_start_hour.
              minute_pct = ->(hours, minutes) do
                total_min = hours * 60 + minutes
                base_min  = week_start_hour * 60
                window    = week_hours * 60
                ((total_min - base_min).to_f / window * 100).clamp(0, 100).round(2)
              end
            %>
            <% partial_absences.each do |a| %>
              <%
                sh, sm = a.start_time.to_s.split(':').map(&:to_i)
                eh, em = a.end_time.to_s.split(':').map(&:to_i)
                next unless sh && eh
                top    = minute_pct.call(sh, sm || 0)
                bottom = minute_pct.call(eh, em || 0)
                title_parts = []
                title_parts << a.user.name if show_users
                title_parts << HrAbsence.kind_label(a.kind)
                title_parts << "#{a.start_time}–#{a.end_time}"
                title_parts << a.reason if a.reason.present?
              %>
              <div class="hr-tc-cal-week-band hr-tc-cal-week-band-<%= a.kind %>"
                   style="top: <%= top %>%; height: <%= (bottom - top).clamp(1, 100) %>%"
                   title="<%= h(title_parts.join(' — ')) %>">
                <span class="hr-tc-cal-week-band-label"><%= h(show_users ? a.user.login : HrAbsence.kind_label(a.kind)) %></span>
              </div>
            <% end %>
            <% day_entries.each do |e| %>
              <%
                started = e.started_at.in_time_zone(tz_for_entries)
                ended_at = e.effective_end_at(as_of: Time.current) || Time.current
                ended = ended_at.in_time_zone(tz_for_entries)
                # Clip to the day boundary for entries that span midnight.
                day_begin = day.in_time_zone(tz_for_entries).beginning_of_day
                day_end   = day.in_time_zone(tz_for_entries).end_of_day
                s = [started, day_begin].max
                t = [ended,   day_end  ].min
                next if t <= s
                top    = minute_pct.call(s.hour, s.min)
                bottom = minute_pct.call(t.hour, t.min)
                bottom = 100.0 if t == day_end
              %>
              <div class="hr-tc-cal-week-band hr-tc-cal-week-band-work"
                   style="top: <%= top %>%; height: <%= (bottom - top).clamp(1, 100) %>%"
                   title="<%= h(show_users && e.user ? e.user.login : '') %> <%= started.strftime('%H:%M') %>–<%= e.ended_at ? ended.strftime('%H:%M') : '…' %>">
                <span class="hr-tc-cal-week-band-label">
                  <%= h(show_users && e.user ? e.user.login + ' ' : '') %><%= started.strftime('%H:%M') %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <% cells = hr_calendar_cells(month) %>
    <table class="hr-tc-calendar-grid">
      <thead>
        <tr>
          <% day_names.each do |dn| %>
            <th><%= dn %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% cells.each_slice(7) do |week| %>
          <tr>
            <% week.each do |day| %>
              <%
                cell_classes = []
                cell_classes << 'hr-tc-cal-empty'   unless day
                cell_classes << 'hr-tc-cal-today'   if day && day == Date.current
                cell_classes << 'hr-tc-cal-weekend' if day && [6, 7].include?(day.cwday)
                cell_classes << 'hr-tc-cal-clickable' if day && clickable

                day_absences = (day && absences_by_day) ? (absences_by_day[day] || []) : []
                day_lectures = (day && lecture_by_day[day]) || []
                day_holidays = (day && holidays_by_day) ? (holidays_by_day[day] || []) : []
                cell_classes << 'hr-tc-cal-has-absence' if day_absences.any? && !show_users
                cell_classes << 'hr-tc-cal-lecture' if day_lectures.any? { |lp| lp.lecture? }
                cell_classes << 'hr-tc-cal-lecture-break' if day_lectures.any? { |lp| lp.break? }
                cell_classes << 'hr-tc-cal-holiday' if day_holidays.any?

                cell_attrs = +%(class="#{cell_classes.join(' ')}")
                if day && clickable
                  cell_attrs << %( data-date="#{day.iso8601}")
                  if day_absences.any?
                    ids = day_absences.map(&:id).join(',')
                    kinds = day_absences.map(&:kind).uniq.join(',')
                    cell_attrs << %( data-absence-ids="#{ids}")
                    cell_attrs << %( data-absence-kinds="#{kinds}")
                  end
                end
                if day && day_holidays.any?
                  names = day_holidays.map { |hd| hd[:name] }.uniq.join(' / ')
                  cell_attrs << %( data-holiday="#{ERB::Util.h(names)}")
                  if day_holidays.any? { |hd| hd[:affected]&.any? || hd[:unaffected]&.any? }
                    payload = day_holidays.map do |hd|
                      {
                        name: hd[:name],
                        regions: hd[:regions],
                        affected:   (hd[:affected]   || []).map { |u| u.name },
                        unaffected: (hd[:unaffected] || []).map { |u| u.name }
                      }
                    end
                    cell_attrs << %( data-holiday-detail="#{ERB::Util.h(payload.to_json)}")
                  end
                end
              %>
              <td <%= cell_attrs.html_safe %>>
                <% if day %>
                  <%
                    kinds_present = day_absences.group_by(&:kind)
                    marker_order  = [HrAbsence::KIND_VACATION, HrAbsence::KIND_SICKNESS, HrAbsence::KIND_OFFSITE, HrAbsence::KIND_SCHOOL, HrAbsence::KIND_BLOCK, HrAbsence::KIND_WORKDAY, HrAbsence::KIND_HOMEOFFICE]
                    has_markers = (day_absences.any? && !show_users) || day_lectures.any? || day_holidays.any?
                  %>
                  <% if has_markers %>
                    <div class="hr-tc-cal-markers">
                      <% if day_holidays.any? %>
                        <span class="hr-tc-cal-marker hr-tc-cal-marker-holiday"
                              title="<%= h(day_holidays.map { |hd| hd[:name] }.uniq.join(' / ')) %>"></span>
                      <% end %>
                      <% if !show_users && day_absences.any? %>
                        <% marker_order.each do |k| %>
                          <% group = kinds_present[k] %>
                          <% next unless group %>
                          <% pending = group.all?(&:requested?) %>
                          <span class="hr-tc-cal-marker hr-tc-cal-marker-<%= k %><%= ' hr-tc-cal-marker-pending' if pending %>"
                                title="<%= h(HrAbsence.kind_label(k)) %><%= ' (' + HrAbsence.status_label(HrAbsence::STATUS_REQUESTED) + ')' if pending %>"></span>
                        <% end %>
                      <% end %>
                      <% day_lectures.each do |lp| %>
                        <span class="hr-tc-cal-marker hr-tc-cal-marker-lecture<%= '-break' if lp.break? %>"
                              title="<%= h(lp.effective_label) %>"></span>
                      <% end %>
                    </div>
                  <% end %>
                  <% if day_link %>
                    <%= link_to day_link.call(day), class: 'hr-tc-cal-day-link' do %>
                      <div class="hr-tc-cal-date"><%= day.day %></div>
                    <% end %>
                  <% else %>
                    <div class="hr-tc-cal-date"><%= day.day %></div>
                  <% end %>
                  <% sec = totals[day].to_i %>
                  <% if sec > 0 %>
                    <div class="hr-tc-cal-hours"><%= hr_format_seconds(sec) %></div>
                  <% end %>
                  <% if show_users && day_absences.any? %>
                    <%
                      pill_limit = 3
                      visible    = day_absences.first(pill_limit)
                      overflow   = day_absences.size - visible.size
                      overflow_title = day_absences.drop(pill_limit)
                                                   .map { |a| "#{a.user.name} (#{HrAbsence.kind_label(a.kind)})" }
                                                   .join("\n")
                    %>
                    <div class="hr-tc-cal-users">
                      <% visible.each do |a| %>
                        <%
                          title_parts = [a.user.name, HrAbsence.kind_label(a.kind)]
                          title_parts << HrAbsence.status_label(a.status) unless a.approved?
                        %>
                        <span class="hr-tc-cal-user-pill hr-tc-cal-user-pill-<%= a.kind %><%= ' hr-tc-cal-user-pill-pending' if a.requested? %>"
                              title="<%= h(title_parts.join(' — ')) %>">
                          <%= h(a.user.login) %>
                        </span>
                      <% end %>
                      <% if overflow.positive? %>
                        <span class="hr-tc-cal-user-pill hr-tc-cal-user-pill-overflow"
                              title="<%= h overflow_title %>">+<%= overflow %></span>
                      <% end %>
                    </div>
                  <% end %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
