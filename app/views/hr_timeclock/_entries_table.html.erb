<% if entries.empty? %>
  <p class="nodata"><%= l(:label_hr_timeclock_state_idle) %></p>
<% else %>
  <table class="list">
    <thead>
      <tr>
        <th><%= l(:label_hr_timeclock_session_started_at) %></th>
        <th><%= l(:label_hr_timeclock_session_ended_at) %></th>
        <th><%= l(:label_hr_timeclock_break_col) %></th>
        <th><%= l(:label_hr_timeclock_worked_col) %></th>
        <th><%= l(:label_hr_timeclock_state) %></th>
      </tr>
    </thead>
    <tbody>
      <% entries.each do |e| %>
        <tr>
          <td><%= format_time(e.started_at) %></td>
          <td><%= e.ended_at ? format_time(e.ended_at) : '—' %></td>
          <td><%= hr_format_seconds(e.total_break_seconds) %></td>
          <td><%= hr_format_seconds(e.net_seconds) %></td>
          <td><%= hr_state_label(e.state) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
