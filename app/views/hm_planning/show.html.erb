<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'hm_timeclock', plugin: 'redmine_hm_cratchmere' %>
<% end %>

<h2><%= l(:label_hm_hr_planning) %></h2>
<p class="hm-tc-section-hint"><%= l(:label_hm_planning_intro) %></p>

<h3><%= l(:label_hm_planning_new) %></h3>
<%= form_with model: @new_absence, url: hm_absences_path, method: :post,
              scope: :hm_absence, local: true, html: { class: 'hm-tc-absence-form' } do |f| %>
  <div class="box tabular">
    <p>
      <%= f.label :kind, l(:label_hm_absence_kind) %>
      <%= f.select :kind, @kinds.map { |k| [HmAbsence.kind_label(k), k] }, {}, { id: 'hm_planning_kind' } %>
    </p>
    <p>
      <%= f.label :starts_on, l(:label_hm_absence_starts_on) %>
      <%= f.date_field :starts_on, required: true %>
    </p>
    <p>
      <%= f.label :ends_on, l(:label_hm_absence_ends_on) %>
      <%= f.date_field :ends_on, required: true %>
    </p>
    <p>
      <%= f.label :reason, l(:label_hm_absence_reason) %>
      <%= f.text_field :reason, size: 50, placeholder: l(:label_hm_planning_reason_placeholder) %>
    </p>
    <p>
      <%= f.label :recurrence, l(:label_hm_recurrence) %>
      <%= f.select :recurrence,
                   [[l(:label_hm_recurrence_none),        HmAbsence::RECURRENCE_NONE],
                    [l(:label_hm_recurrence_weekly),      HmAbsence::RECURRENCE_WEEKLY],
                    [l(:label_hm_recurrence_biweekly),    HmAbsence::RECURRENCE_BIWEEKLY],
                    [l(:label_hm_recurrence_four_weekly), HmAbsence::RECURRENCE_4_WEEKLY],
                    [l(:label_hm_recurrence_monthly),     HmAbsence::RECURRENCE_MONTHLY],
                    [l(:label_hm_recurrence_quarterly),   HmAbsence::RECURRENCE_QUARTERLY],
                    [l(:label_hm_recurrence_half_yearly), HmAbsence::RECURRENCE_HALFYEARLY],
                    [l(:label_hm_recurrence_yearly),      HmAbsence::RECURRENCE_YEARLY]],
                   {}, { id: 'hm_planning_recurrence' } %>
    </p>
    <p id="hm_planning_recurrence_until_row">
      <%= f.label :recurrence_until, l(:label_hm_recurrence_until) %>
      <%= f.date_field :recurrence_until %>
      <em class="info"><%= l(:label_hm_recurrence_until_hint) %></em>
    </p>
  </div>
  <p><%= submit_tag l(:button_hm_planning_create), class: 'button-positive' %></p>
<% end %>

<h3><%= l(:label_hm_timeclock_calendar) %></h3>
<%= render partial: 'hm_timeclock/calendar', locals: {
      month: @month, entries: [], user: User.current,
      base_path: ->(m) { hm_planning_path(month: m.strftime('%Y-%m')) },
      absences_by_day: @absences_by_day
    } %>

<h3><%= l(:label_hm_planning_list) %></h3>
<%= render partial: 'hm_timeclock/absence_list', locals: { absences: @absences } %>

<%= render partial: 'hm_timeclock/absence_edit_modal' %>

<script>
  (function () {
    var rec = document.getElementById('hm_planning_recurrence');
    var untilRow = document.getElementById('hm_planning_recurrence_until_row');
    function toggle() {
      if (!rec || !untilRow) return;
      untilRow.style.display = (rec.value && rec.value !== '<%= HmAbsence::RECURRENCE_NONE %>') ? '' : 'none';
    }
    if (rec) { rec.addEventListener('change', toggle); toggle(); }
  })();
</script>
